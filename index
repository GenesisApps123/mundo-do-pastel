<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>MUNDO DO PASTEL</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#f8c400;
    font-family:'Poppins',sans-serif;
    padding:20px;
    color:#222;
}

.container{
    max-width:900px;
    margin:auto;
    background:white;
    border-radius:35px;
    padding:25px;
    box-shadow:0 15px 40px rgba(0,0,0,0.2);
}

.logo{
    width:240px;
    display:block;
    margin:auto;
    margin-bottom:20px;
}

h1{
    text-align:center;
    color:#0b9637;
    font-size:2.4rem;
    margin-bottom:10px;
}

.subtitulo{
    text-align:center;
    margin-bottom:30px;
    color:#555;
}

.section{
    background:#fffdf3;
    border:3px solid #f8c400;
    border-radius:25px;
    padding:20px;
    margin-bottom:25px;
}

.section h2{
    color:#e11212;
    margin-bottom:15px;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
    gap:15px;
}

.card{
    background:white;
    border-radius:20px;
    padding:15px;
    border:2px solid #ececec;
}

.card h3{
    color:#0b9637;
    margin-bottom:10px;
}

.info{
    margin-bottom:8px;
    font-size:0.95rem;
}

.quantidade{
    width:100%;
    padding:12px;
    border-radius:12px;
    border:2px solid #ddd;
    font-size:1rem;
}

.item{
    display:flex;
    align-items:center;
    gap:10px;
    background:white;
    padding:12px;
    border-radius:15px;
    border:2px solid #eee;
    margin-bottom:10px;
}

.item label{
    flex:1;
}

input[type="checkbox"]{
    width:20px;
    height:20px;
    accent-color:#0b9637;
}

input[type="text"],
textarea,
select{
    width:100%;
    padding:15px;
    border-radius:15px;
    border:2px solid #ddd;
    margin-top:10px;
    font-size:1rem;
}

textarea{
    resize:none;
    height:100px;
}

.total{
    background:#0b9637;
    color:white;
    text-align:center;
    padding:25px;
    border-radius:25px;
}

.total h2{
    font-size:2rem;
}

button{
    width:100%;
    border:none;
    padding:18px;
    margin-top:20px;
    border-radius:20px;
    background:#e11212;
    color:white;
    font-size:1.2rem;
    font-weight:bold;
    cursor:pointer;
}

button:hover{
    background:#c40d0d;
}

.erro{
    border:2px solid red !important;
}

.erro-texto{
    color:red;
    font-size:0.9rem;
    margin-top:5px;
}

.aviso{
    background:#fff3cd;
    border:2px solid #ffe08a;
    padding:15px;
    border-radius:15px;
    margin-top:15px;
    color:#856404;
}

@media(max-width:600px){

    h1{
        font-size:1.8rem;
    }

    .container{
        padding:18px;
    }

}

</style>
</head>

<body>

<div class="container">

<img src="logo.png" class="logo">

<h1>MUNDO DO PASTEL</h1>

<p class="subtitulo">
Monte seu pedido completo 🍴
</p>

<div class="section">

<h2>🥟 Escolha seus pastéis</h2>

<div class="grid">

<div class="card">

<h3>Pastel Pequeno</h3>

<p class="info">R$ 5,00 cada</p>

<p class="info">Mínimo: 3 unidades</p>

<p class="info"><strong>Total mínimo: R$ 15,00</strong></p>

<input type="number" min="0" value="0" id="pequeno" class="quantidade">

</div>

<div class="card">

<h3>Pastel Médio</h3>

<p class="info">R$ 7,00 cada</p>

<p class="info">Mínimo: 3 unidades</p>

<p class="info"><strong>Total mínimo: R$ 21,00</strong></p>

<input type="number" min="0" value="0" id="medio" class="quantidade">

</div>

<div class="card">

<h3>Pastel Grande</h3>

<p class="info">R$ 9,99 cada</p>

<p class="info">Pode pedir apenas 1</p>

<input type="number" min="0" value="0" id="grande" class="quantidade">

</div>

</div>

<div class="aviso">
⚠️ Pastéis pequenos e médios precisam ter no mínimo 3 unidades.
</div>

</div>

<div class="section">

<h2>🔥 Sabores</h2>

<div class="item">
<input type="checkbox" class="sabor" value="Carne com Queijo">
<label>Carne com Queijo</label>
</div>

<div class="item">
<input type="checkbox" class="sabor" value="Frango com Catupiry">
<label>Frango com Catupiry</label>
</div>

<div class="item">
<input type="checkbox" class="sabor" value="Pizza">
<label>Pizza</label>
</div>

<div class="item">
<input type="checkbox" class="sabor" value="Calabresa com Queijo">
<label>Calabresa com Queijo</label>
</div>

<div class="item">
<input type="checkbox" class="sabor" value="Presunto e Queijo">
<label>Presunto e Queijo</label>
</div>

<div class="item">
<input type="checkbox" class="sabor" value="Bacon com Cheddar">
<label>Bacon com Cheddar</label>
</div>

<div class="item">
<input type="checkbox" class="sabor" value="Carne Seca com Queijo">
<label>Carne Seca com Queijo</label>
</div>

<div class="item">
<input type="checkbox" class="sabor" value="Chocolate com Banana">
<label>Chocolate com Banana</label>
</div>

<div class="item">
<input type="checkbox" class="sabor" value="Romeu e Julieta">
<label>Romeu e Julieta</label>
</div>

<div class="item">
<input type="checkbox" class="sabor" value="Camarão Cremoso">
<label>Camarão Cremoso</label>
</div>

</div>

<div class="section">

<h2>🥤 Bebidas</h2>

<div class="item">
<input type="checkbox" class="bebida" data-preco="4.99" value="Suco Natural - R$ 4,99">
<label>Suco Natural - R$ 4,99</label>
</div>

<div class="item">
<input type="checkbox" class="bebida" data-preco="4.99" value="Latinha - R$ 4,99">
<label>Latinha - R$ 4,99</label>
</div>

<div class="item">
<input type="checkbox" class="bebida" data-preco="9.99" value="Refrigerante 1L - R$ 9,99">
<label>Refrigerante 1L - R$ 9,99</label>
</div>

<div class="item">
<input type="checkbox" class="bebida" data-preco="14.99" value="Refrigerante 2L - R$ 14,99">
<label>Refrigerante 2L - R$ 14,99</label>
</div>

</div>

<div class="section">

<h2>💳 Forma de pagamento</h2>

<select id="pagamento">

<option value="">Selecione</option>

<option>Pix</option>

<option>Dinheiro</option>

<option>Cartão de Débito</option>

<option>Cartão de Crédito</option>

</select>

</div>

<div class="section">

<h2>📍 Dados para entrega</h2>

<input type="text" id="nome" placeholder="Seu nome completo">

<div id="erroNome" class="erro-texto"></div>

<textarea id="endereco" placeholder="Digite seu endereço completo"></textarea>

<div id="erroEndereco" class="erro-texto"></div>

</div>

<div class="total">

<p>Total do Pedido</p>

<h2 id="total">R$ 0,00</h2>

</div>

<button onclick="finalizarPedido()">

FINALIZAR PEDIDO NO WHATSAPP

</button>

</div>

<script>

const pequeno = document.getElementById('pequeno');
const medio = document.getElementById('medio');
const grande = document.getElementById('grande');
const totalEl = document.getElementById('total');

function calcularTotal(){

    let total = 0;

    total += (parseInt(pequeno.value) || 0) * 5;

    total += (parseInt(medio.value) || 0) * 7;

    total += (parseInt(grande.value) || 0) * 9.99;

    document.querySelectorAll('.bebida').forEach(item=>{

        if(item.checked){

            total += parseFloat(item.dataset.preco);

        }

    });

    totalEl.innerText = total.toLocaleString('pt-BR',{

        style:'currency',

        currency:'BRL'

    });

}

document.querySelectorAll('input').forEach(item=>{

    item.addEventListener('input',calcularTotal);

    item.addEventListener('change',calcularTotal);

});

function vibrar(){

    if(navigator.vibrate){

        navigator.vibrate(300);

    }

}

function finalizarPedido(){

    let valido = true;

    const nome = document.getElementById('nome');

    const endereco = document.getElementById('endereco');

    const pagamento = document.getElementById('pagamento');

    nome.classList.remove('erro');

    endereco.classList.remove('erro');

    pagamento.classList.remove('erro');

    document.getElementById('erroNome').innerText='';

    document.getElementById('erroEndereco').innerText='';

    if(nome.value.trim()===''){

        nome.classList.add('erro');

        document.getElementById('erroNome').innerText='Digite seu nome completo';

        valido = false;

    }

    if(endereco.value.trim()===''){

        endereco.classList.add('erro');

        document.getElementById('erroEndereco').innerText='Digite seu endereço';

        valido = false;

    }

    if(pagamento.value===''){

        pagamento.classList.add('erro');

        valido = false;

    }

    const qtdPequeno = parseInt(pequeno.value)||0;

    const qtdMedio = parseInt(medio.value)||0;

    const qtdGrande = parseInt(grande.value)||0;

    if(qtdPequeno>0 && qtdPequeno<3){

        alert('Pastel pequeno precisa de no mínimo 3 unidades.');

        vibrar();

        return;

    }

    if(qtdMedio>0 && qtdMedio<3){

        alert('Pastel médio precisa de no mínimo 3 unidades.');

        vibrar();

        return;

    }

    if(qtdPequeno===0 && qtdMedio===0 && qtdGrande===0){

        alert('Escolha pelo menos um pastel.');

        vibrar();

        return;

    }

    if(!valido){

        vibrar();

        return;

    }

    let sabores = [];

    document.querySelectorAll('.sabor').forEach(item=>{

        if(item.checked){

            sabores.push(item.value);

        }

    });

    let bebidas = [];

    document.querySelectorAll('.bebida').forEach(item=>{

        if(item.checked){

            bebidas.push(item.value);

        }

    });

    let mensagem = '';

    mensagem += '🍴 *NOVO PEDIDO - MUNDO DO PASTEL*%0A%0A';

    mensagem += '👤 *Nome:* ' + nome.value + '%0A';

    mensagem += '📍 *Endereço:* ' + endereco.value + '%0A%0A';

    mensagem += '🥟 *PASTÉIS*%0A';

    if(qtdPequeno>0){

        mensagem += '- '+qtdPequeno+' Pastel Pequeno = R$ '+(qtdPequeno*5).toFixed(2)+'%0A';

    }

    if(qtdMedio>0){

        mensagem += '- '+qtdMedio+' Pastel Médio = R$ '+(qtdMedio*7).toFixed(2)+'%0A';

    }

    if(qtdGrande>0){

        mensagem += '- '+qtdGrande+' Pastel Grande = R$ '+(qtdGrande*9.99).toFixed(2)+'%0A';

    }

    mensagem += '%0A🔥 *SABORES*%0A';

    if(sabores.length>0){

        sabores.forEach(item=>{

            mensagem += '• '+item+'%0A';

        });

    }else{

        mensagem += 'Nenhum sabor selecionado%0A';

    }

    mensagem += '%0A🥤 *BEBIDAS*%0A';

    if(bebidas.length>0){

        bebidas.forEach(item=>{

            mensagem += '• '+item+'%0A';

        });

    }else{

        mensagem += 'Nenhuma bebida%0A';

    }

    mensagem += '%0A💳 *Pagamento:* '+pagamento.value+'%0A';

    mensagem += '%0A💰 *TOTAL:* '+totalEl.innerText;

    const numero = '5588993082035';

    window.open(

        'https://wa.me/'+numero+'?text='+mensagem,

        '_blank'

    );

}

calcularTotal();

</script>

</body>
</html>
