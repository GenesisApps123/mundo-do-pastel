<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mundo do Pastel</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Poppins', sans-serif;
    background: #f8c400;
    color: #222;
    min-height: 100vh;
    padding: 20px;
}

.container {
    max-width: 900px;
    margin: auto;
    background: #fff;
    border-radius: 35px;
    padding: 25px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.2);
}

.logo {
    width: 230px;
    display: block;
    margin: 0 auto 20px auto;
}

h1 {
    text-align: center;
    color: #0b9637;
    font-size: 2.3rem;
    margin-bottom: 10px;
}

.subtitulo {
    text-align: center;
    margin-bottom: 30px;
    color: #555;
}

.section {
    background: #fffdf3;
    border: 3px solid #f8c400;
    border-radius: 25px;
    padding: 20px;
    margin-bottom: 25px;
}

.section h2 {
    color: #e11212;
    margin-bottom: 15px;
    font-size: 1.4rem;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
}

.card {
    background: white;
    border-radius: 20px;
    padding: 15px;
    border: 2px solid #ececec;
    transition: 0.3s;
}

.card:hover {
    transform: scale(1.02);
    border-color: #0b9637;
}

.card h3 {
    color: #0b9637;
    margin-bottom: 10px;
}

.info {
    font-size: 0.95rem;
    margin-bottom: 10px;
}

.quantidade {
    width: 100%;
    padding: 12px;
    border-radius: 12px;
    border: 2px solid #ddd;
    font-size: 1rem;
}

.sabor-item,
.bebida-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: white;
    padding: 12px;
    border-radius: 15px;
    margin-bottom: 10px;
    border: 2px solid #eee;
}

.sabor-item label,
.bebida-item label {
    flex: 1;
    margin-left: 10px;
}

input[type="checkbox"] {
    width: 20px;
    height: 20px;
    accent-color: #0b9637;
}

input[type="text"],
textarea,
select {
    width: 100%;
    padding: 15px;
    border-radius: 15px;
    border: 2px solid #ddd;
    font-size: 1rem;
    margin-top: 10px;
}

textarea {
    resize: none;
    height: 100px;
}

.total-box {
    background: #0b9637;
    color: white;
    text-align: center;
    padding: 20px;
    border-radius: 25px;
    margin-top: 20px;
}

.total-box h2 {
    font-size: 2rem;
}

button {
    width: 100%;
    margin-top: 25px;
    padding: 18px;
    border: none;
    border-radius: 20px;
    background: #e11212;
    color: white;
    font-size: 1.2rem;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
}

button:hover {
    background: #c40d0d;
    transform: scale(1.01);
}

.erro {
    border: 2px solid red !important;
}

.erro-msg {
    color: red;
    margin-top: 5px;
    font-size: 0.9rem;
}

.aviso {
    background: #fff3cd;
    border: 2px solid #ffe08a;
    padding: 15px;
    border-radius: 15px;
    margin-top: 10px;
    color: #856404;
    font-weight: 500;
}

@media(max-width: 600px){
    h1 {
        font-size: 1.8rem;
    }

    .container {
        padding: 18px;
    }
}
</style>
</head>
<body>

<div class="container">

<img src="logo.png" class="logo" alt="Mundo do Pastel">

<h1>MUNDO DO PASTEL</h1>
<p class="subtitulo">Monte seu pedido completo em poucos segundos 🍴</p>

<div class="section">
<h2>🥟 Escolha seus pastéis</h2>

<div class="grid">

<div class="card">
<h3>Pastel Pequeno</h3>
<p class="info">R$ 5,00 cada</p>
<p class="info">Mínimo para entrega: 3 unidades</p>
<p class="info"><strong>Total mínimo: R$ 15,00</strong></p>
<input type="number" min="0" value="0" id="pequeno" class="quantidade">
</div>

<div class="card">
<h3>Pastel Médio</h3>
<p class="info">R$ 7,00 cada</p>
<p class="info">Mínimo para entrega: 3 unidades</p>
<p class="info"><strong>Total mínimo: R$ 21,00</strong></p>
<input type="number" min="0" value="0" id="medio" class="quantidade">
</div>

<div class="card">
<h3>Pastel Grande</h3>
<p class="info">R$ 9,99 cada</p>
<p class="info">Pode pedir apenas 1 unidade</p>
<input type="number" min="0" value="0" id="grande" class="quantidade">
</div>

</div>

<div class="aviso">
⚠️ Pastéis pequenos e médios precisam ter no mínimo 3 unidades caso sejam escolhidos.
</div>
</div>

<div class="section">
<h2>🔥 Escolha os sabores</h2>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Carne com Queijo">
<label>Carne com Queijo</label>
</div>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Frango com Catupiry">
<label>Frango com Catupiry</label>
</div>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Pizza">
<label>Pizza</label>
</div>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Calabresa com Queijo">
<label>Calabresa com Queijo</label>
</div>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Presunto e Queijo">
<label>Presunto e Queijo</label>
</div>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Bacon com Cheddar">
<label>Bacon com Cheddar</label>
</div>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Carne Seca com Queijo">
<label>Carne Seca com Queijo</label>
</div>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Chocolate com Banana">
<label>Chocolate com Banana</label>
</div>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Romeu e Julieta">
<label>Romeu e Julieta</label>
</div>

<div class="sabor-item">
<input type="checkbox" class="sabor" value="Camarão Cremoso">
<label>Camarão Cremoso</label>
</div>

</div>

<div class="section">
<h2>🥤 Bebidas</h2>

<div class="bebida-item">
<input type="checkbox" class="bebida" data-preco="4.99" value="Suco Natural - R$ 4,99">
<label>Suco Natural - R$ 4,99</label>
</div>

<div class="bebida-item">
<input type="checkbox" class="bebida" data-preco="4.99" value="Latinha - R$ 4,99">
<label>Latinha - R$ 4,99</label>
</div>

<div class="bebida-item">
<input type="checkbox" class="bebida" data-preco="9.99" value="Refrigerante 1L - R$ 9,99">
<label>Refrigerante 1L - R$ 9,99</label>
</div>

<div class="bebida-item">
<input type="checkbox" class="bebida" data-preco="14.99" value="Refrigerante 2L - R$ 14,99">
<label>Refrigerante 2L - R$ 14,99</label>
</div>

</div>

<div class="section">
<h2>💳 Forma de pagamento</h2>

<select id="pagamento">
<option value="">Selecione</option>
<option>Pix</option>
<option>Dinheiro</option>
<option>Cartão de Débito</option>
<option>Cartão de Crédito</option>
</select>
</div>

<div class="section">
<h2>📍 Dados para entrega</h2>

<input type="text" id="nome" placeholder="Seu nome completo">
<div id="erroNome" class="erro-msg"></div>

<textarea id="endereco" placeholder="Digite seu endereço completo"></textarea>
<div id="erroEndereco" class="erro-msg"></div>

</div>

<div class="total-box">
<p>Total do Pedido</p>
<h2 id="total">R$ 0,00</h2>
</div>

<button onclick="finalizarPedido()">
FINALIZAR PEDIDO NO WHATSAPP
</button>

</div>

<script>
const pequeno = document.getElementById('pequeno');
const medio = document.getElementById('medio');
const grande = document.getElementById('grande');
const totalEl = document.getElementById('total');

function calcularTotal() {

    let total = 0;

    const qtdPequeno = parseInt(pequeno.value) || 0;
    const qtdMedio = parseInt(medio.value) || 0;
    const qtdGrande = parseInt(grande.value) || 0;

    total += qtdPequeno * 5;
    total += qtdMedio * 7;
    total += qtdGrande * 9.99;

    document.querySelectorAll('.bebida').forEach(item => {
        if(item.checked){
            total += parseFloat(item.dataset.preco);
        }
    });

    totalEl.innerText = total.toLocaleString('pt-BR', {
        style: 'currency',
        currency: 'BRL'
    });
}

pequeno.addEventListener('input', calcularTotal);
medio.addEventListener('input', calcularTotal);
grande.addEventListener('input', calcularTotal);

const bebidas = document.querySelectorAll('.bebida');
bebidas.forEach(item => {
    item.addEventListener('change', calcularTotal);
});

function vibrar(){
    if(navigator.vibrate){
        navigator.vibrate(300);
    }
}

function finalizarPedido(){

    let valido = true;

    const nome = document.getElementById('nome');
    const endereco = document.getElementById('endereco');
    const pagamento = document.getElementById('pagamento');

    document.getElementById('erroNome').innerText = '';
    document.getElementById('erroEndereco').innerText = '';

    nome.classList.remove('erro');
    endereco.classList.remove('erro');
    pagamento.classList.remove('erro');

    if(nome.value.trim() === ''){
        nome.classList.add('erro');
        document.getElementById('erroNome').innerText = 'Digite seu nome completo';
        valido = false;
    }

    if(endereco.value.trim() === ''){
        endereco.classList.add('erro');
        document.getElementById('erroEndereco').innerText = 'Digite seu endereço';
        valido = false;
    }

    if(pagamento.value === ''){
        pagamento.classList.add('erro');
        valido = false;
    }

    const qtdPequeno = parseInt(pequeno.value) || 0;
    const qtdMedio = parseInt(medio.value) || 0;
    const qtdGrande = parseInt(grande.value) || 0;

    if(qtdPequeno > 0 && qtdPequeno < 3){
        alert('O pastel pequeno precisa ter no mínimo 3 unidades.');
        vibrar();
        return;
    }

    if(qtdMedio > 0 && qtdMedio < 3){
        alert('O pastel médio precisa ter no mínimo 3 unidades.');
        vibrar();
        return;
    }

    if(qtdPequeno === 0 && qtdMedio === 0 && qtdGrande === 0){
        alert('Escolha pelo menos um pastel.');
        vibrar();
        return;
    }

    if(!valido){
        vibrar();
        return;
    }

    let sabores = [];
    document.querySelectorAll('.sabor').forEach(item => {
        if(item.checked){
            sabores.push(item.value);
        }
    });

    let bebidasSelecionadas = [];
    document.querySelectorAll('.bebida').forEach(item => {
        if(item.checked){
            bebidasSelecionadas.push(item.value);
        }
    });

    const totalPedido = totalEl.innerText;

    let mensagem = `🍴 *NOVO PEDIDO - MUNDO DO PASTEL*%0A%0A`;

    mensagem += `👤 *Nome:* ${nome.value}%0A`;
    mensagem += `📍 *Endereço:* ${endereco.value}%0A%0A`;

    mensagem += `🥟 *PASTÉIS*%0A`;

    if(qtdPequeno > 0){
        mensagem += `- ${qtdPequeno} Pastel(is) Pequeno(s) - R$ ${(qtdPequeno * 5).toFixed(2)}%0A`;
    }

    if(qtdMedio > 0){
        mensagem += `- ${qtdMedio} Pastel(is) Médio(s) - R$ ${(qtdMedio * 7).toFixed(2)}%0A`;
    }

    if(qtdGrande > 0){
        mensagem += `- ${qtdGrande} Pastel(is) Grande(s) - R$ ${(qtdGrande * 9.99).toFixed(2)}%0A`;
    }

    mensagem += `%0A🔥 *Sabores Escolhidos:*%0A`;

    if(sabores.length > 0){
        sabores.forEach(item => {
            mensagem += `• ${item}%0A`;
        });
    } else {
        mensagem += `Nenhum sabor selecionado%0A`;
    }

    mensagem += `%0A🥤 *Bebidas:*%0A`;

    if(bebidasSelecionadas.length > 0){
        bebidasSelecionadas.forEach(item => {
            mensagem += `• ${item}%0A`;
        });
    } else {
        mensagem += `Nenhuma bebida selecionada%0A`;
    }

    mensagem += `%0A💳 *Pagamento:* ${pagamento.value}%0A`;
    mensagem += `%0A💰 *TOTAL:* ${totalPedido}`;

    const numero = '5588993082035';

    const url = `https://wa.me/${numero}?text=${mensagem}`;

    window.open(url, '_blank');
}

calcularTotal();
</script>

</body>
</html>

